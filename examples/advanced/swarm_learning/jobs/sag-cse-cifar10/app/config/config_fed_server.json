{
  "format_version": 2,
  "alpha": 1.0,
  "server": {
      "heart_beat_timeout": 600
  },
  "task_data_filters": [],
  "task_result_filters": [],
  "components": [
      {
        "id": "persistor",
        "name": "PTFileModelPersistor",
        "args": {
            "model": {
                "path": "pt.cifar10_nets.SimpleCNN",
                "args": {}
            }
        }
      },
      {
        "id": "shareable_generator",
        "path": "nvflare.app_common.ccwf.comps.simple_model_shareable_generator.SimpleModelShareableGenerator",
        "args": {}
      },
      {
        "id": "aggregator",
        "path": "nvflare.app_common.aggregators.intime_accumulate_model_aggregator.InTimeAccumulateWeightedAggregator",
        "args": {
          "expected_data_kind": "WEIGHT_DIFF"
        }
      },
      {
          "id": "model_selector",
          "name": "IntimeModelSelector",
          "args": {}
      },
      {
          "id": "model_locator",
          "name": "PTFileModelLocator",
          "args": {
              "pt_persistor_id": "persistor"
          }
      },
      {
          "id": "json_generator",
          "name": "ValidationJsonGenerator",
          "args": {}
      }
  ],
  "workflows": [
      {
          "id": "scatter_gather_ctl",
          "name": "ScatterAndGather",
          "args": {
              "min_clients": 2,
              "num_rounds": 3,
              "start_round": 0,
              "wait_time_after_min_received": 10,
              "aggregator_id": "aggregator",
              "persistor_id": "persistor",
              "shareable_generator_id": "shareable_generator",
              "train_task_name": "train",
              "train_timeout": 0
          }
      },
      {
          "id": "cross_site_model_eval",
          "name": "CrossSiteModelEval",
          "args": {
              "model_locator_id": "model_locator",
              "submit_model_timeout": 600,
              "validation_timeout": 6000,
              "cleanup_models": true
          }
      }
  ]
}